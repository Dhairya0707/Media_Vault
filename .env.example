# Cloudinary Configuration
# Get these from your Cloudinary Dashboard (Settings > API Keys)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Asset Management
# The folder in Cloudinary where assets will be stored and retrieved from
CLOUDINARY_FOLDER=media-vault

# Security
# 4-digit PIN for the AuthGate (fallback is 8253)
NEXT_PUBLIC_APP_PIN=8253
